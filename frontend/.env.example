APP_NAME=Feishu CLI Web
APP_ENV=development
DEBUG=true
API_PREFIX=/api/v1
# LLM 配置
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus
ANTHROPIC_API_KEY=

LARK_CLI_LLM_TIMEOUT=25
LARK_CLI_COMMAND_TIMEOUT=30

# API 目标地址
VITE_API_TARGET=http://127.0.0.1:8000
