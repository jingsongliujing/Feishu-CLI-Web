APP_NAME=Feishu CLI Web
APP_ENV=development
DEBUG=true
API_PREFIX=/api/v1

# Optional. Without a model key, direct lark-cli commands and many heuristic flows still work.
# Click "一键配置 Qwen" in the web UI to write the Bailian-compatible config below.
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus
ANTHROPIC_API_KEY=

LARK_CLI_LLM_TIMEOUT=25
LARK_CLI_COMMAND_TIMEOUT=30
